{
  "name": "brain-tree-os",
  "version": "0.1.4",
  "description": "Brian viewer and Codex-first project memory for AI-native repos",
  "license": "MIT",
  "author": "Brian",
  "homepage": "https://github.com/fisherjames/brain-tree-os",
  "repository": {
    "type": "git",
    "url": "https://github.com/fisherjames/brain-tree-os.git"
  },
  "bugs": {
    "url": "https://github.com/fisherjames/brain-tree-os/issues"
  },
  "keywords": [
    "brian",
    "braintree",
    "brain",
    "ai",
    "project-management",
    "codex",
    "agents",
    "obsidian",
    "open-source"
  ],
  "bin": {
    "brain-tree-os": "packages/cli/dist/index.js",
    "brian": "packages/cli/dist/index.js"
  },
  "files": [
    "packages/cli/dist/",
    "packages/web/.next/",
    "!packages/web/.next/cache/",
    "!packages/web/.next/standalone/",
    "!packages/web/.next/trace/",
    "!packages/web/.next/diagnostics/",
    "packages/web/dist/",
    "packages/web/public/",
    "packages/web/package.json",
    "demo/"
  ],
  "dependencies": {
    "chokidar": "^4.0.0",
    "next": "^15.2.0",
    "open": "^10.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ws": "^8.18.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "packageManager": "npm@10.8.2",
  "scripts": {
    "build": "npm run build --workspace=packages/cli && npm run build --workspace=packages/web",
    "typecheck": "npm run typecheck --workspace=packages/cli && npm run typecheck --workspace=packages/web",
    "install:cli": "npm run build && npm link",
    "remove:cli": "npm unlink -g brain-tree-os brian"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
