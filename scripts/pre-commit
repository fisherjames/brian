#!/bin/sh

# Prevent committing .env files
if git diff --cached --name-only | grep -qE '\.env(\.local)?$'; then
  echo "Error: Attempting to commit .env file. Remove it from staging with:"
  echo "  git reset HEAD <file>"
  exit 1
fi

# Governance baseline: ensure doctrine lint still passes.
if ! npm run --silent typecheck --workspace=packages/cli >/dev/null 2>&1; then
  echo "Error: CLI typecheck failed."
  exit 1
fi

if ! node packages/cli/dist/index.js doctrine-lint >/dev/null 2>&1; then
  echo "Error: doctrine-lint failed. Fix doctrine drift before commit."
  exit 1
fi
